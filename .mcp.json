{
  "name": "budget-planner-ai-mcp",
  "description": "AI-powered budget planner ai MCP server for agents. Supports create budget, add expense, add income. By MEOK AI Labs.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "create_budget",
      "description": "Create a monthly budget with category allocations",
      "parameters": {
        "type": "object",
        "properties": {
          "month": {
            "type": "string"
          },
          "income": {
            "type": "number"
          },
          "categories": {
            "type": "object"
          }
        },
        "required": [
          "month",
          "income",
          "categories"
        ]
      }
    },
    {
      "name": "add_expense",
      "description": "Record an expense transaction",
      "parameters": {
        "type": "object",
        "properties": {
          "budget_month": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "description": {
            "type": "string"
          },
          "date": {
            "type": "string"
          }
        },
        "required": [
          "budget_month",
          "category",
          "amount"
        ]
      }
    },
    {
      "name": "add_income",
      "description": "Record income for a budget period",
      "parameters": {
        "type": "object",
        "properties": {
          "budget_month": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "date": {
            "type": "string"
          }
        },
        "required": [
          "budget_month",
          "source",
          "amount"
        ]
      }
    },
    {
      "name": "get_budget_status",
      "description": "Get budget status for a month",
      "parameters": {
        "type": "object",
        "properties": {
          "month": {
            "type": "string"
          }
        },
        "required": [
          "month"
        ]
      }
    },
    {
      "name": "get_transactions",
      "description": "List transactions with optional filters",
      "parameters": {
        "type": "object",
        "properties": {
          "budget_month": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "start_date": {
            "type": "string"
          },
          "end_date": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        },
        "required": []
      }
    },
    {
      "name": "create_goal",
      "description": "Create a savings goal",
      "parameters": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "target_amount": {
            "type": "number"
          },
          "target_date": {
            "type": "string"
          },
          "category": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "target_amount",
          "target_date"
        ]
      }
    },
    {
      "name": "update_goal_progress",
      "description": "Add contribution to a savings goal",
      "parameters": {
        "type": "object",
        "properties": {
          "goal_id": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          }
        },
        "required": [
          "goal_id",
          "amount"
        ]
      }
    },
    {
      "name": "get_goals",
      "description": "Get all savings goals with progress",
      "parameters": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          }
        },
        "required": []
      }
    },
    {
      "name": "get_analytics",
      "description": "Get spending analytics",
      "parameters": {
        "type": "object",
        "properties": {
          "month": {
            "type": "string"
          },
          "category": {
            "type": "string"
          }
        },
        "required": []
      }
    },
    {
      "name": "set_budget_alert",
      "description": "Set spending alert threshold for a category",
      "parameters": {
        "type": "object",
        "properties": {
          "month": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "threshold_percent": {
            "type": "number"
          }
        },
        "required": [
          "month",
          "category",
          "threshold_percent"
        ]
      }
    },
    {
      "name": "get_category_spending",
      "description": "Get detailed spending by category",
      "parameters": {
        "type": "object",
        "properties": {
          "month": {
            "type": "string"
          },
          "category": {
            "type": "string"
          }
        },
        "required": []
      }
    },
    {
      "name": "transfer_funds",
      "description": "Transfer between budget categories",
      "parameters": {
        "type": "object",
        "properties": {
          "month": {
            "type": "string"
          },
          "from_category": {
            "type": "string"
          },
          "to_category": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          }
        },
        "required": [
          "month",
          "from_category",
          "to_category",
          "amount"
        ]
      }
    },
    {
      "name": "rollover_unused",
      "description": "Rollover unused budget to next month",
      "parameters": {
        "type": "object",
        "properties": {
          "source_month": {
            "type": "string"
          },
          "target_month": {
            "type": "string"
          }
        },
        "required": [
          "source_month",
          "target_month"
        ]
      }
    }
  ]
}